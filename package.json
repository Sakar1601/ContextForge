{
  "name": "contextforge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "check": "tsc -b && eslint . && vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "dev": "pnpm --filter @contextforge/extension dev",
    "build": "pnpm --filter @contextforge/extension build",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "onnxruntime-node"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@resvg/resvg-js": "^2.6.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
