{
  "manifest_version": 3,
  "name": "ContextForge",
  "version": "0.1.0",
  "description": "Capture and reuse AI conversations across platforms.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "ContextForge"
  },
  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/claude.ts"]
    }
  ],
  "permissions": ["storage", "alarms", "offscreen", "tabs"],
  "host_permissions": ["https://claude.ai/*"]
}
