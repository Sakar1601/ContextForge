{
  "manifest_version": 3,
  "name": "ContextForge",
  "version": "0.0.1",
  "description": "Capture and reuse AI conversations across platforms.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "ContextForge"
  },
  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },
  "permissions": ["storage", "alarms", "offscreen"]
}
