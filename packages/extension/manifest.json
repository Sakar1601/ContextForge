{
  "manifest_version": 3,
  "name": "ContextForge",
  "version": "0.1.0",
  "description": "Capture and reuse AI conversations across platforms.",
  "icons": {
    "16":  "src/icons/icon16.png",
    "48":  "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "ContextForge",
    "default_icon": {
      "16":  "src/icons/icon16.png",
      "48":  "src/icons/icon48.png",
      "128": "src/icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/graph/index.html", "src/offscreen/index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },
  "content_scripts": [
    { "matches": ["https://claude.ai/*"],          "js": ["src/content/claude.ts"] },
    { "matches": ["https://chatgpt.com/*"],         "js": ["src/content/chatgpt.ts"] },
    { "matches": ["https://gemini.google.com/*"],   "js": ["src/content/gemini.ts"] },
    { "matches": ["https://www.perplexity.ai/*"],   "js": ["src/content/perplexity.ts"] },
    { "matches": ["https://chat.deepseek.com/*"],   "js": ["src/content/deepseek.ts"] },
    { "matches": ["https://mail.google.com/*"],     "js": ["src/content/gmail.ts"] }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": ["storage", "alarms", "offscreen", "tabs"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://chat.deepseek.com/*",
    "https://mail.google.com/*"
  ]
}
